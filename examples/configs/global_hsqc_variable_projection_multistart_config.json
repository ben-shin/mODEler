{
  "model": "examples/configs/model_first_order.txt",
  "data": "examples/configs/example_hsqc_peaks.csv",
  "time_column": "time",
  "observed_species": "A",
  "parameters": {
    "k1f": {
      "initial_guess": 0.1,
      "lower_bound": 0.000001,
      "upper_bound": 10.0
    }
  },
  "initial_conditions": {
    "A": {
      "value": 1.0,
      "mode": "fixed",
      "lower_bound": 0.0,
      "upper_bound": 2.0
    },
    "B": {
      "value": 0.0,
      "mode": "fixed",
      "lower_bound": 0.0,
      "upper_bound": 2.0
    }
  },
  "fit_scale": true,
  "fit_offset": true,
  "method": "trf",
  "loss": "linear",
  "rtol": 1e-8,
  "atol": 1e-10,
  "max_nfev": 5000,
  "sort_by": "aic",
  "n_starts": 8,
  "random_seed": 1,
  "log_uniform": true,
  "max_missing_fraction": 0.25,
  "min_initial_intensity": null,
  "initial_points": 1,
  "min_dynamic_range": null,
  "interpolate_missing": true,
  "use_variable_projection": true,
  "variable_projection_backend": "numpy",
  "variable_projection_method": "LSODA",
  "show_progress": true,
  "output_dir": "examples/configs/outputs/global_hsqc_variable_projection_multistart",
  "no_plots": true
}
