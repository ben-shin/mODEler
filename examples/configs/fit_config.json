{
  "model": "examples/configs/model_first_order.txt",
  "data": "examples/configs/example_timecourse.csv",
  "time_column": "time",
  "signal_columns": ["A", "B"],
  "mapping": {
    "A": "A",
    "B": "B"
  },
  "parameters": {
    "k1f": {
      "initial_guess": 0.2,
      "lower_bound": 0.001,
      "upper_bound": 10.0
    }
  },
  "initial_conditions": {
    "A": {
      "value": 1.0,
      "mode": "fixed",
      "lower_bound": 0.0,
      "upper_bound": 10.0
    },
    "B": {
      "value": 0.0,
      "mode": "fixed",
      "lower_bound": 0.0,
      "upper_bound": 10.0
    }
  },
  "signal_weights": {
    "A": 1.0,
    "B": 1.0
  },
  "method": "trf",
  "loss": "linear",
  "rtol": 1e-8,
  "atol": 1e-10,
  "max_nfev": 1000,
  "output_dir": "examples/configs/outputs/fit",
  "no_plots": true
}
