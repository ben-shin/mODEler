{
  "use_variable_projection": true,
  "model": "examples/configs/model_first_order.txt",
  "data": "examples/configs/example_hsqc_peaks.csv",
  "time_column": "time",
  "signal_columns": null,
  "exclude_columns": null,
  "observed_species": "A",
  "output_dir": "examples/configs/outputs/global_hsqc_variable_projection_profile_likelihood",
  "parameters": {
    "k1f": {
      "initial_guess": 0.1,
      "lower_bound": 1e-06,
      "upper_bound": 10.0
    }
  },
  "initial_conditions": {
    "A": {
      "value": 1.0,
      "mode": "fixed"
    },
    "B": {
      "value": 0.0,
      "mode": "fixed"
    }
  },
  "profile_parameters": [
    "k1f"
  ],
  "profile_n_points": 9,
  "profile_span_factor": 10.0,
  "profile_log_space": true,
  "fit_scale": true,
  "fit_offset": true,
  "method": "trf",
  "loss": "linear",
  "max_nfev": null,
  "rtol": 1e-06,
  "atol": 1e-09,
  "variable_projection_backend": "numpy",
  "variable_projection_method": "LSODA",
  "max_missing_fraction": 0.0,
  "min_initial_intensity": null,
  "initial_points": 1,
  "min_dynamic_range": null,
  "interpolate_missing": true,
  "engine_name": "reference"
}
